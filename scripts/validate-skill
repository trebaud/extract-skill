#!/bin/bash

# Skill Validation Script
# Validates the format and structure of Agent Skills according to SKILL.md requirements

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_error() { echo -e "${RED}ERROR: $1${NC}" >&2; }
print_success() { echo -e "${GREEN}✓ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_info() { echo -e "${BLUE}ℹ $1${NC}"; }

# Function to validate skill name format
validate_skill_name() {
    local skill_name="$1"
    local skill_dir="$2"
    
    # Check if name matches directory name
    if [[ "$skill_name" != "$(basename "$skill_dir")" ]]; then
        print_error "Skill name '$skill_name' does not match directory name '$(basename "$skill_dir")'"
        return 1
    fi
    
    # Check naming convention (lowercase-hyphenated, max 64 chars)
    if [[ ! "$skill_name" =~ ^[a-z0-9-]+$ ]] || [[ ${#skill_name} -gt 64 ]]; then
        print_error "Skill name must be lowercase-hyphenated and max 64 characters: '$skill_name'"
        return 1
    fi
    
    print_success "Skill name format is valid: $skill_name"
    return 0
}

# Function to validate YAML frontmatter
validate_frontmatter() {
    local skill_file="$1"
    
    # Check if file starts with frontmatter delimiter
    if ! grep -q "^---" "$skill_file"; then
        print_error "SKILL.md must start with YAML frontmatter (---)"
        return 1
    fi
    
    # Extract frontmatter
    local frontmatter
    frontmatter=$(sed -n '/^---/,/^---/p' "$skill_file" | sed '1d;$d')
    
    # Check required fields
    if ! echo "$frontmatter" | grep -q "^name:"; then
        print_error "Frontmatter missing required 'name' field"
        return 1
    fi
    
    if ! echo "$frontmatter" | grep -q "^description:"; then
        print_error "Frontmatter missing required 'description' field"
        return 1
    fi
    
    # Extract values for validation
    local name description
    name=$(echo "$frontmatter" | grep "^name:" | cut -d: -f2 | xargs)
    description=$(echo "$frontmatter" | grep "^description:" | cut -d: -f2 | xargs)
    
    # Validate name format
    if [[ ! "$name" =~ ^[a-z0-9-]+$ ]] || [[ ${#name} -gt 64 ]]; then
        print_error "Name must be lowercase-hyphenated and max 64 characters: '$name'"
        return 1
    fi
    
    # Validate description length (max 1024 chars)
    if [[ ${#description} -gt 1024 ]]; then
        print_error "Description exceeds 1024 characters (${#description} chars)"
        return 1
    fi
    
    print_success "Frontmatter is valid"
    return 0
}

# Function to validate SKILL.md content
validate_skill_content() {
    local skill_file="$1"
    
    # Check file size and line count
    local line_count
    line_count=$(wc -l < "$skill_file")
    
    if [[ $line_count -gt 500 ]]; then
        print_warning "SKILL.md exceeds 500 lines ($line_count lines). Consider splitting into references/"
    fi
    
    # Check for progressive disclosure patterns
    if grep -q "\.md\)" "$skill_file"; then
        print_info "Found progressive disclosure patterns (references to .md files)"
    fi
    
    # Check for script references
    if grep -q "scripts/" "$skill_file"; then
        print_info "Found script references"
    fi
    
    # Check for duplicate frontmatter
    local frontmatter_count
    frontmatter_count=$(grep -c "^---" "$skill_file")
    if [[ $frontmatter_count -gt 2 ]]; then
        print_error "Multiple frontmatter sections detected"
        return 1
    fi
    
    print_success "SKILL.md content validation passed"
    return 0
}

# Function to validate directory structure
validate_directory_structure() {
    local skill_dir="$1"
    local skill_file="$skill_dir/SKILL.md"
    
    # Check if SKILL.md exists
    if [[ ! -f "$skill_file" ]]; then
        print_error "SKILL.md not found in skill directory"
        return 1
    fi
    
    # Check optional subdirectories
    local has_optional_dirs=false
    for subdir in scripts references assets; do
        if [[ -d "$skill_dir/$subdir" ]]; then
            has_optional_dirs=true
            print_info "Found $subdir/ directory"
            
            # Validate scripts are executable
            if [[ "$subdir" == "scripts" ]]; then
                local script_count=0
                local non_executable_count=0
                while IFS= read -r -d '' script; do
                    ((script_count++))
                    if [[ ! -x "$script" ]]; then
                        ((non_executable_count++))
                        print_warning "Script is not executable: $(basename "$script")"
                    fi
                done < <(find "$skill_dir/scripts" -type f -print0 2>/dev/null || true)
                
                if [[ $script_count -gt 0 ]]; then
                    if [[ $non_executable_count -eq 0 ]]; then
                        print_success "All $script_count scripts are executable"
                    fi
                fi
            fi
        fi
    done
    
    if [[ $has_optional_dirs == false ]]; then
        print_info "No optional subdirectories found (scripts/, references/, assets/)"
    fi
    
    print_success "Directory structure is valid"
    return 0
}

# Function to validate file references
validate_file_references() {
    local skill_dir="$1"
    local skill_file="$skill_dir/SKILL.md"
    
    # Find all markdown file references
    local references
    references=$(grep -o '\[[^]]*\]([^)]*\.md)' "$skill_file" || true)
    
    if [[ -n "$references" ]]; then
        print_info "Validating file references..."
        local missing_refs=0
        
        while IFS= read -r ref; do
            # Extract filename from markdown link
            local filename
            filename=$(echo "$ref" | sed 's/.*(\([^)]*\.md\)).*/\1/')
            
            # Skip external URLs
            if [[ "$filename" =~ ^https?:// ]]; then
                continue
            fi
            
            # Check if referenced file exists
            if [[ ! -f "$skill_dir/$filename" ]]; then
                print_error "Referenced file not found: $filename"
                ((missing_refs++))
            fi
        done <<< "$references"
        
        if [[ $missing_refs -eq 0 ]]; then
            print_success "All file references exist"
        else
            return 1
        fi
    fi
    
    return 0
}

# Function to validate content density
validate_content_density() {
    local skill_file="$1"
    
    # Extract body content (after frontmatter)
    local body_content
    body_content=$(sed '1,/^---$/d; /^---$/,$d' "$skill_file")
    
    # Check for common low-value patterns
    local warning_count=0
    
    # Check for marketing language indicators (exclude from documentation examples)
    if echo "$body_content" | grep -vi -E "(example|documentation)" | grep -qi -E "(revolutionary|cutting-edge|state-of-the-art|unprecedented|game-changing)"; then
        print_warning "Found potential marketing language in content"
        ((warning_count++))
    fi
    
    # Check for excessive repetition
    local word_count
    word_count=$(echo "$body_content" | wc -w)
    if [[ $word_count -lt 50 ]]; then
        print_warning "SKILL.md body seems very short ($word_count words)"
    fi
    
    # Check for actionable content density (basic heuristic)
    local actionable_patterns
    actionable_patterns=$(echo "$body_content" | grep -c -E "(Use when|When you need|For|Apply|Create|Implement|Generate)" || true)
    
    if [[ $actionable_patterns -eq 0 ]] && [[ $word_count -gt 100 ]]; then
        print_warning "Low actionable pattern density found - consider adding more 'Use when' patterns"
    fi
    
    print_success "Content density analysis completed"
    return 0
}

# Main validation function
validate_skill() {
    local skill_dir="$1"
    
    print_info "Validating skill at: $skill_dir"
    
    if [[ ! -d "$skill_dir" ]]; then
        print_error "Skill directory does not exist: $skill_dir"
        return 1
    fi
    
    local skill_file="$skill_dir/SKILL.md"
    
    # Extract skill name from frontmatter
    if [[ ! -f "$skill_file" ]]; then
        print_error "SKILL.md not found"
        return 1
    fi
    
    local skill_name
    skill_name=$(sed -n '/^---/,/^---/p' "$skill_file" | grep "^name:" | cut -d: -f2 | xargs || echo "")
    
    if [[ -z "$skill_name" ]]; then
        print_error "Could not extract skill name from SKILL.md"
        return 1
    fi
    
    # Run all validations
    local validation_passed=true
    
    validate_skill_name "$skill_name" "$skill_dir" || validation_passed=false
    validate_directory_structure "$skill_dir" || validation_passed=false
    validate_frontmatter "$skill_file" || validation_passed=false
    validate_skill_content "$skill_file" || validation_passed=false
    validate_file_references "$skill_dir" || validation_passed=false
    validate_content_density "$skill_file" || validation_passed=false
    
    echo
    if [[ $validation_passed == true ]]; then
        print_success "Skill validation PASSED: $skill_name"
        return 0
    else
        print_error "Skill validation FAILED: $skill_name"
        return 1
    fi
}

# Function to show usage
show_usage() {
    echo "Usage: $0 <skill-directory>"
    echo "Validates the format and structure of an Agent Skill"
    echo ""
    echo "Example:"
    echo "  $0 ./my-skill"
    echo "  $0 /path/to/skills/extract-skill"
}

# Main script execution
main() {
    if [[ $# -eq 0 ]]; then
        print_error "No skill directory specified"
        show_usage
        exit 1
    fi
    
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        show_usage
        exit 0
    fi
    
    local skill_dir="$1"
    
    # Handle relative paths
    if [[ ! "$skill_dir" = /* ]]; then
        skill_dir="$(pwd)/$skill_dir"
    fi
    
    validate_skill "$skill_dir"
}

# Run main function with all arguments
main "$@"